        "<a href=\"https://colab.research.google.com/github/vjraj11/codex-playground/blob/main/Copy_of_Week_3_Day_4_models.ipynb\" target=\"_parent\"><img src=\"https://colab.research.google.com/assets/colab-badge.svg\" alt=\"Open In Colab\"/></a>"
